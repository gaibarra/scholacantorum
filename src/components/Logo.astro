---
import { SITE } from 'astrowind:config';
---

<span class="self-center flex items-center gap-2 ml-2 mr-4 rtl:ml-0 rtl:mr-2">
  <img
    src="/logo-scm.jpg"
    alt="Logo Schola Cantorum de México"
    class="h-12 w-12 rounded-full object-cover ring-2 ring-primary/30 shadow-md shadow-primary/10"
    width="48"
    height="48"
  />
  <span class="text-2xl md:text-xl font-heading font-bold text-gray-900 whitespace-nowrap dark:text-white tracking-tight">
    {SITE?.name}
  </span>
</span>
