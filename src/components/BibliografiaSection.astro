---
import { bibliography, type BibliographyItem } from "../data/bibliography";

const featuredItem = bibliography.find((item) => item.featured);
const regularItems = bibliography.filter((item) => !item.featured);
---

<section id="bibliografia" class="bg-white py-12 md:py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl">
      <p class="text-sm font-semibold uppercase tracking-[0.25em] text-neutral-500">
        Bibliografía
      </p>
      <h2 class="mt-4 text-3xl md:text-4xl font-semibold tracking-tight text-neutral-900 lg:text-5xl">
        Publicaciones y materiales de consulta
      </h2>
      <p class="mt-6 text-lg leading-8 text-neutral-700">
        Esta sección reúne materiales pedagógicos, antologías vocales, repertorio coral
        y ediciones académicas vinculadas con Schola Cantorum de México A.C. y con la
        labor musical y editorial de Alfredo Mendoza.
      </p>
    </div>

    <div class="mt-10 md:mt-14 grid grid-cols-1 gap-6 lg:grid-cols-3">
      {regularItems.slice(0, 3).map((item) => (
        <article class="rounded-3xl border border-neutral-200 bg-neutral-50 p-5 md:p-6 shadow-sm transition duration-300 hover:-translate-y-1 hover:shadow-md">
          <div class="flex flex-wrap items-center justify-between gap-3">
            <span class="text-xs font-semibold uppercase tracking-[0.2em] text-neutral-500">
              {item.category}
            </span>
            <span class="rounded-full bg-neutral-900 px-3 py-1 text-xs font-medium text-white">
              {item.badge}
            </span>
          </div>

          <h3 class="mt-5 text-2xl font-semibold text-neutral-900">
            {item.title}
          </h3>

          <p class="mt-4 leading-7 text-neutral-700">
            {item.description}
          </p>
        </article>
      ))}
    </div>

    {featuredItem && (
      <article class="mt-6 rounded-3xl border border-neutral-200 bg-white p-6 md:p-8 shadow-sm">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
          <div class="max-w-3xl">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-neutral-500">
              {featuredItem.category}
            </p>
            <h3 class="mt-3 text-3xl font-semibold text-neutral-900 md:text-4xl">
              {featuredItem.title}
            </h3>
            <p class="mt-4 text-lg leading-8 text-neutral-700">
              {featuredItem.description}
            </p>
          </div>

          <span class="inline-flex w-fit shrink-0 rounded-full bg-neutral-900 px-4 py-2 text-sm font-medium text-white">
            {featuredItem.badge}
          </span>
        </div>

        {featuredItem.items && (
          <div class="mt-6 md:mt-8 grid grid-cols-1 gap-6 lg:grid-cols-2">
            <div class="rounded-2xl border border-neutral-200 bg-neutral-50 p-5 md:p-6">
              <h4 class="text-xl font-semibold text-neutral-900">
                Educanto · Niños
              </h4>
              <ul class="mt-4 space-y-4 text-neutral-700">
                {featuredItem.items
                  .filter((entry) => entry.includes("Niños"))
                  .map((entry) => (
                    <li class="leading-7">{entry}</li>
                  ))}
              </ul>
            </div>

            <div class="rounded-2xl border border-neutral-200 bg-neutral-50 p-5 md:p-6">
              <h4 class="text-xl font-semibold text-neutral-900">
                Educanto · Jóvenes
              </h4>
              <ul class="mt-4 space-y-4 text-neutral-700">
                {featuredItem.items
                  .filter((entry) => entry.includes("Jóvenes"))
                  .map((entry) => (
                    <li class="leading-7">{entry}</li>
                  ))}
              </ul>
            </div>
          </div>
        )}
      </article>
    )}

    <div class="mt-6 grid grid-cols-1 gap-6 md:grid-cols-2">
      {regularItems.slice(3).map((item) => (
        <article class="rounded-3xl border border-neutral-200 bg-neutral-50 p-5 md:p-6 shadow-sm transition duration-300 hover:-translate-y-1 hover:shadow-md">
          <div class="flex flex-wrap items-center justify-between gap-3">
            <span class="text-xs font-semibold uppercase tracking-[0.2em] text-neutral-500">
              {item.category}
            </span>
            <span class="rounded-full bg-neutral-900 px-3 py-1 text-xs font-medium text-white">
              {item.badge}
            </span>
          </div>

          <h3 class="mt-5 text-2xl font-semibold text-neutral-900">
            {item.title}
          </h3>

          <p class="mt-4 leading-7 text-neutral-700">
            {item.description}
          </p>
        </article>
      ))}
    </div>

    <div class="mt-8 md:mt-12 rounded-3xl bg-neutral-900 px-6 py-8 md:px-8 md:py-10 text-white">
      <h3 class="text-2xl font-semibold">
        Líneas de consulta sugeridas
      </h3>

      <div class="mt-6 grid grid-cols-1 gap-6 md:grid-cols-3">
        <div>
          <p class="font-semibold text-white">Pedagogía vocal</p>
          <p class="mt-2 leading-7 text-neutral-200">
            Métodos progresivos para formación infantil y juvenil mediante el canto.
          </p>
        </div>

        <div>
          <p class="font-semibold text-white">Repertorio coral</p>
          <p class="mt-2 leading-7 text-neutral-200">
            Obras, arreglos y antologías para coros escolares, juveniles e institucionales.
          </p>
        </div>

        <div>
          <p class="font-semibold text-white">Edición e investigación</p>
          <p class="mt-2 leading-7 text-neutral-200">
            Materiales académicos y proyectos editoriales vinculados con tradición vocal y musicológica.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
