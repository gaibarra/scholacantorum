---
import Layout from '~/layouts/PageLayout.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import BibliografiaSection from '~/components/BibliografiaSection.astro';
import { Icon } from 'astro-icon/components';

const metadata = {
  title: 'Inicio',
  description:
    'Formación musical coral de excelencia para niños, jóvenes y adultos en el área metropolitana de la Ciudad de México.',
};

const razones = [
  {
    icon: 'tabler:music',
    title: 'Formación Coral de Excelencia',
    description:
      'Programas diseñados para desarrollar la técnica vocal, el oído musical y la sensibilidad artística desde temprana edad.',
  },
  {
    icon: 'tabler:users',
    title: 'Maestros de Renombre',
    description:
      'Equipo docente conformado por jóvenes maestros bajo la dirección de Alfredo Mendoza, catedrático de la Facultad de Música de la UNAM.',
  },
  {
    icon: 'tabler:plane',
    title: 'Viaja con la Música',
    description:
      'Nuestros alumnos participan en giras nacionales e internacionales, descubriendo el mundo a través del arte.',
  },
  {
    icon: 'tabler:building-fortress',
    title: 'Escenarios de Primer Nivel',
    description:
      'Presentaciones en foros como el Palacio de Bellas Artes, Sala Nezahualcóyotl, Sala Silvestre Revueltas y Auditorio Blas Galindo.',
  },
  {
    icon: 'tabler:heart-handshake',
    title: 'Becas para el Talento',
    description:
      'Descuentos de 50% y hasta 100% para quienes lo requieren, condicionados al compromiso con el estudio.',
  },
  {
    icon: 'tabler:brain',
    title: 'Desarrollo Integral',
    description:
      'La música fortalece la disciplina, el trabajo en equipo, la confianza y las habilidades cognitivas.',
  },
];

const stats = [
  { value: '35+', label: 'Años de Trayectoria' },
  { value: '1,000+', label: 'Alumnos Formados' },
  { value: '50+', label: 'Giras Internacionales' },
  { value: '4', label: 'Programas Corales' },
];
---

<Layout metadata={metadata}>
  <!-- ═══════════ HERO — Logo Protagonista ═══════════ -->
  <section class="relative md:-mt-[76px] not-prose overflow-hidden">
    <!-- BG: Radial gradient + subtle texture -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute inset-0 bg-gradient-to-b from-[rgb(6_10_24)] via-[rgb(10_18_38)] to-[rgb(8_15_30)]"></div>
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_rgb(212_175_55_/_6%)_0%,_transparent_70%)]"></div>
      <!-- Subtle ornamental circles -->
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full border border-primary/[0.04]"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] rounded-full border border-primary/[0.03]"></div>
    </div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6">
      <div class="pt-0 md:pt-[76px]"></div>
      <div class="py-16 md:py-24 lg:py-28">
        <div class="text-center max-w-4xl mx-auto">

          <!-- Logo protagonista -->
          <div class="flex justify-center mb-10 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
            <div class="relative">
              <img
                src="/logo-scm.jpg"
                alt="Schola Cantorum de México"
                class="relative z-10 w-40 h-40 md:w-52 md:h-52 rounded-full object-cover ring-4 ring-primary/40 animate-glow-pulse"
                width="208"
                height="208"
                loading="eager"
              />
              <!-- Halo dorado -->
              <div class="absolute inset-0 -m-3 rounded-full bg-gradient-to-tr from-primary/20 via-transparent to-primary/20 blur-xl animate-float"></div>
            </div>
          </div>

          <!-- Tagline -->
          <p class="text-sm md:text-base text-primary font-semibold tracking-[0.25em] uppercase mb-4 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
            Formación Coral de Excelencia
          </p>

          <!-- Heading -->
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-heading font-bold leading-tight tracking-tight mb-6 dark:text-gray-100 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
            Formando voces que<br class="hidden sm:inline" />
            <span class="bg-gradient-to-r from-primary via-gold-light to-primary bg-clip-text text-transparent">
              inspiran al mundo
            </span>
          </h1>

          <!-- Subtitle -->
          <p class="text-lg md:text-xl text-slate-300/80 max-w-2xl mx-auto mb-10 leading-relaxed intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
            La Schola Cantorum de México ofrece formación musical coral de excelencia para niños con talento en el área
            metropolitana de la Ciudad de México.
          </p>

          <!-- CTAs -->
          <div class="flex flex-col sm:flex-row justify-center gap-4 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
            <a href="/inscripciones" class="btn-gold">
              <Icon name="tabler:music" class="w-5 h-5 mr-2" />
              ¡Inscribe a tu hijo!
            </a>
            <a href="/programas" class="btn-outline-gold">
              Conoce nuestros programas
            </a>
          </div>

        </div>
      </div>
    </div>

    <!-- Bottom fade -->
    <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-[rgb(8_15_30)] to-transparent"></div>
  </section>

  <!-- ═══════════ STATS — Prueba Social ═══════════ -->
  <section class="relative py-16 -mt-6 z-10">
    <div class="mx-auto max-w-5xl px-4 sm:px-6">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {stats.map((stat) => (
          <div class="glass-card text-center intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-scale-in">
            <div class="text-3xl md:text-4xl font-heading font-bold text-primary mb-1">{stat.value}</div>
            <div class="text-sm text-slate-400">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════ SOBRE NOSOTROS ═══════════ -->
  <section class="py-16">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div class="intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
          <p class="text-sm text-primary font-semibold tracking-[0.2em] uppercase mb-3">Nuestra Historia</p>
          <h2 class="text-3xl md:text-4xl font-heading font-bold dark:text-white mb-6">
            Formando voces e inculcando música
          </h2>
          <p class="text-lg text-slate-300/80 leading-relaxed mb-4">
            La Schola Cantorum de México lleva treinta y cinco años brindando formación músico-vocal de excelencia a niños
            y jóvenes. Aquí pueden descubrir su potencial artístico mediante programas de educación musical, canto coral y
            canto individual, que los capacitan para presentar conciertos con repertorio clásico nacional e internacional.
          </p>
          <p class="text-lg text-slate-300/80 leading-relaxed">
            Los grupos de estudio están a cargo de jóvenes maestros bajo la dirección del destacado especialista Alfredo
            Mendoza, catedrático de la Facultad de Música de la UNAM, con 50 años de experiencia en la formación de coros
            y cantantes infantiles y juveniles.
          </p>
        </div>
        <div class="flex flex-col gap-4 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
          <a href="/galeria" class="glass-card group flex items-center gap-4">
            <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center group-hover:bg-primary/20 transition-colors">
              <Icon name="tabler:camera" class="w-6 h-6 text-primary" />
            </div>
            <div>
              <h3 class="font-semibold dark:text-white group-hover:text-primary transition-colors">Galería Audiovisual</h3>
              <p class="text-sm text-slate-400">Explora nuestras presentaciones en fotos y videos</p>
            </div>
          </a>
          <a href="/contact" class="glass-card group flex items-center gap-4">
            <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center group-hover:bg-primary/20 transition-colors">
              <Icon name="tabler:map-pin" class="w-6 h-6 text-primary" />
            </div>
            <div>
              <h3 class="font-semibold dark:text-white group-hover:text-primary transition-colors">Ubicación</h3>
              <p class="text-sm text-slate-400">Monte Albán 594, Col. Letrán Valle, CDMX</p>
            </div>
          </a>
          <a href="/quienes-somos" class="glass-card group flex items-center gap-4">
            <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center group-hover:bg-primary/20 transition-colors">
              <Icon name="tabler:info-circle" class="w-6 h-6 text-primary" />
            </div>
            <div>
              <h3 class="font-semibold dark:text-white group-hover:text-primary transition-colors">¿Quiénes Somos?</h3>
              <p class="text-sm text-slate-400">Conoce nuestra trayectoria y misión</p>
            </div>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════ ACTIVIDADES PERMANENTES ═══════════ -->
  <section class="py-16 relative">
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-primary/[0.03] to-transparent pointer-events-none"></div>
    <div class="relative mx-auto max-w-6xl px-4 sm:px-6">
      <div class="text-center mb-12 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
        <p class="text-sm text-primary font-semibold tracking-[0.2em] uppercase mb-3">Programas</p>
        <h2 class="text-3xl md:text-4xl font-heading font-bold dark:text-white">Actividades permanentes</h2>
      </div>
      <div class="grid gap-6 md:grid-cols-2">
        <article class="glass-card intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center">
              <Icon name="tabler:music" class="w-5 h-5 text-primary" />
            </div>
            <h3 class="text-xl font-heading font-semibold dark:text-white">Canto coral · Niños</h3>
          </div>
          <ul class="space-y-3 text-slate-300/80">
            <li class="flex items-start gap-2">
              <span class="text-primary mt-1.5 text-xs">●</span>
              <span><strong class="text-white">Grupo infantil de iniciación (6-10 años):</strong> Martes, 5:00-6:30 p.m.</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-primary mt-1.5 text-xs">●</span>
              <span><strong class="text-white">Coro de Niños (9-13 años):</strong> Lunes y miércoles, 5:00-7:00 p.m.</span>
            </li>
          </ul>
        </article>
        <article class="glass-card intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center">
              <Icon name="tabler:microphone-2" class="w-5 h-5 text-primary" />
            </div>
            <h3 class="text-xl font-heading font-semibold dark:text-white">Jóvenes y adultos</h3>
          </div>
          <ul class="space-y-3 text-slate-300/80">
            <li class="flex items-start gap-2">
              <span class="text-primary mt-1.5 text-xs">●</span>
              <span><strong class="text-white">Grupo juvenil preparatorio (14-20 años):</strong> Martes, 6:30-8:00 p.m.</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-primary mt-1.5 text-xs">●</span>
              <span><strong class="text-white">Coro de Cámara (14-30 años):</strong> Lunes y miércoles, 7:00-8:30 p.m.</span>
            </li>
          </ul>
        </article>
      </div>
    </div>
  </section>

  <!-- ═══════════ PRÓXIMAS FECHAS ═══════════ -->
  <section class="py-16">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 grid gap-6 lg:grid-cols-2">
      <article class="glass-card intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center">
            <Icon name="tabler:calendar-event" class="w-5 h-5 text-primary" />
          </div>
          <h2 class="text-2xl font-heading font-bold dark:text-white">Próximo período de admisión</h2>
        </div>
        <p class="text-slate-300/80">Clases abiertas y pruebas de voz: <strong class="text-primary">Lunes 16 y miércoles 18 de marzo de 2026</strong>.</p>
        <ul class="mt-4 space-y-2 text-slate-300/80">
          <li class="flex items-start gap-2">
            <span class="text-primary mt-1.5 text-xs">●</span>
            <span><strong class="text-white">Coro de Niños y Grupo infantil de iniciación:</strong> 6:00 p.m.</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-primary mt-1.5 text-xs">●</span>
            <span><strong class="text-white">Coro de Cámara y Grupo juvenil preparatorio:</strong> 7:30 p.m.</span>
          </li>
        </ul>
      </article>
      <article class="glass-card intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center">
            <Icon name="tabler:school" class="w-5 h-5 text-primary" />
          </div>
          <h2 class="text-2xl font-heading font-bold dark:text-white">Cursos de pedagogía musical</h2>
        </div>
        <p class="text-slate-300/80">
          <strong class="text-white">Próximo curso:</strong> Iniciación músico-vocal del niño (prácticas de rítmica, entonación, lectura y técnica vocal).
        </p>
        <p class="mt-3 text-slate-300/80"><strong class="text-white">Imparte:</strong> Alfredo Mendoza M.</p>
        <p class="mt-3 text-slate-300/80">
          <strong class="text-white">Materiales:</strong> Antologías IN PILCUICATL y EDUCANTO, NIÑOS I.
        </p>
        <p class="mt-3 text-slate-300/80">
          <strong class="text-white">Sede:</strong> Centro Coral, Monte Albán 594, Col. Letrán Valle.
        </p>
        <p class="mt-3 text-slate-300/80"><strong class="text-white">Fechas:</strong> 9-11 de abril de 2026, 9:00-13:30 hrs.</p>
        <p class="mt-3 text-slate-300/80"><strong class="text-white">Preinscripción:</strong> WhatsApp 55 7195 5571.</p>
      </article>
    </div>
  </section>

  <!-- ═══════════ ¿POR QUÉ ELEGIRNOS? ═══════════ -->
  <section class="py-16 relative">
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-primary/[0.03] to-transparent pointer-events-none"></div>
    <div class="relative mx-auto max-w-6xl px-4 sm:px-6">
      <div class="text-center mb-12 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
        <p class="text-sm text-primary font-semibold tracking-[0.2em] uppercase mb-3">Excelencia</p>
        <h2 class="text-3xl md:text-4xl font-heading font-bold dark:text-white">¿Por qué elegir la Schola Cantorum?</h2>
        <p class="mt-3 text-lg text-slate-400 max-w-2xl mx-auto">Más de 35 años formando voces infantiles y juveniles en México.</p>
      </div>
      <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {razones.map((razon) => (
          <article class="glass-card group intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
            <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center mb-4 group-hover:bg-primary/20 transition-colors">
              <Icon name={razon.icon} class="w-5 h-5 text-primary" />
            </div>
            <h3 class="font-heading font-semibold dark:text-white mb-2">{razon.title}</h3>
            <p class="text-sm text-slate-400 leading-relaxed">{razon.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════ BIBLIOGRAFÍA ═══════════ -->
  <BibliografiaSection />

  <!-- ═══════════ CTA FINAL ═══════════ -->
  <section class="py-16">
    <div class="mx-auto max-w-4xl px-4 sm:px-6">
      <div class="relative rounded-2xl overflow-hidden intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
        <!-- Gold gradient background -->
        <div class="absolute inset-0 bg-gradient-to-br from-primary via-[rgb(180_148_45)] to-primary"></div>
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_50%,_rgb(255_255_255_/_15%)_0%,_transparent_60%)]"></div>
        <div class="relative p-8 md:p-12 text-center">
          <h2 class="text-3xl md:text-4xl font-heading font-bold text-navy-dark mb-4">Inscripciones abiertas 2026</h2>
          <p class="text-lg text-navy-dark/80 max-w-2xl mx-auto mb-8">
            Abrimos nuestras puertas a niños con talento musical del área metropolitana de la Ciudad de México.
          </p>
          <div class="flex flex-col sm:flex-row justify-center gap-4">
            <a href="/programas" class="inline-flex items-center justify-center rounded-full font-semibold text-base py-3.5 px-8 bg-navy-dark text-primary hover:bg-navy-deep transition-all duration-300 shadow-lg">
              <Icon name="tabler:school" class="w-5 h-5 mr-2" />
              Conoce nuestros programas
            </a>
            <a href="/inscripciones" class="inline-flex items-center justify-center rounded-full font-semibold text-base py-3.5 px-8 bg-white/20 text-navy-dark border-2 border-navy-dark/20 hover:bg-white/30 transition-all duration-300">
              <Icon name="tabler:music" class="w-5 h-5 mr-2" />
              ¡Inscríbete!
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
