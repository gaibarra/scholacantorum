---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Programas',
  description:
    'Programas de iniciación músico-vocal, conciertos y grabaciones, formación de solistas y becas para el talento.',
};
---

<Layout metadata={metadata}>
  <Hero tagline="Programas">
    <Fragment slot="title">
      Conoce nuestros<br class="hidden xl:inline" />
      <span class="text-accent dark:text-white"> programas</span>
    </Fragment>
    <Fragment slot="subtitle">
      Formación músico-vocal para niños, jóvenes y adultos con enfoque en repertorio clásico nacional e internacional.
    </Fragment>
  </Hero>

  <section class="py-14">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <article class="rounded-xl border border-slate-200 bg-white p-7 dark:border-slate-700 dark:bg-slate-800">
        <h2 class="text-2xl font-bold dark:text-white">Iniciación músico-vocal</h2>
        <p class="mt-4 text-muted dark:text-slate-300">
          Preparación auditiva y física elemental para manejar ritmo, entonación, lectura musical y técnica vocal.
        </p>
        <p class="mt-3 text-muted dark:text-slate-300">
          Este entrenamiento se brinda en grupos iniciales abiertos para quienes no tienen estudios anteriores:
        </p>
        <ul class="mt-4 space-y-2 text-muted dark:text-slate-300">
          <li><strong>Grupo infantil de iniciación</strong> · Ingreso: 6-10 años · Ensayos: Martes, 5:00-6:30 p.m.</li>
          <li><strong>Grupo juvenil preparatorio</strong> · Ingreso: 14-20 años · Ensayos: Martes, 6:30-8:00 p.m.</li>
        </ul>
      </article>
    </div>
  </section>

  <section class="py-14 bg-slate-50 dark:bg-slate-900/40">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 grid gap-6 md:grid-cols-2">
      <article class="rounded-xl border border-slate-200 bg-white p-7 dark:border-slate-700 dark:bg-slate-800">
        <h2 class="text-2xl font-bold dark:text-white">Conciertos y grabaciones</h2>
        <p class="mt-4 text-muted dark:text-slate-300">
          Trabajo del Coro de Niños y Coro de Cámara (coro femenino y de varones), con preparación musical continua y
          presentaciones en escenarios de primer nivel.
        </p>
        <ul class="mt-4 space-y-2 text-muted dark:text-slate-300">
          <li><strong>Coro de Niños (9-13 años):</strong> Lunes y miércoles, 5:00-7:00 p.m.</li>
          <li><strong>Coro de Cámara (14-30 años):</strong> Lunes y miércoles, 7:00-8:30 p.m.</li>
        </ul>
      </article>

      <article class="rounded-xl border border-slate-200 bg-white p-7 dark:border-slate-700 dark:bg-slate-800">
        <h2 class="text-2xl font-bold dark:text-white">Formación de solistas</h2>
        <p class="mt-4 text-muted dark:text-slate-300">
          En ambos coros principales se observa el desempeño individual de voz y musicalidad para preparar a cantores
          destacados en partes especiales de concierto, representaciones operísticas o grabaciones.
        </p>
      </article>
    </div>
  </section>

  <section class="py-14">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <article class="rounded-xl border border-slate-200 bg-white p-7 dark:border-slate-700 dark:bg-slate-800">
        <h2 class="text-2xl font-bold dark:text-white">Becas para el talento</h2>
        <p class="mt-4 text-muted dark:text-slate-300">
          Para las distintas actividades se pide una cuota mensual de recuperación; sin embargo, se otorgan descuentos
          del 50% e incluso del 100% a quienes lo requieren, condicionados a un firme compromiso con el estudio.
        </p>
      </article>
    </div>
  </section>

  <CallToAction actions={[{ variant: 'primary', text: '¡Inscríbete ahora!', href: '/inscripciones', icon: 'tabler:music' }]}>
    <Fragment slot="title">¿Listo para comenzar?</Fragment>
    <Fragment slot="subtitle">
      Encuentra el programa ideal y agenda tu proceso de ingreso para este período.
    </Fragment>
  </CallToAction>
</Layout>
